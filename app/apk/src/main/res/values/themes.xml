<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Base.V23.Theme.Foundation.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">?colorPrimary</item>
        <item name="colorSecondary">?colorSecondary</item>
        <item name="colorSurface">?colorSurface</item>
        <item name="colorOnSurface">?colorOnSurface</item>
